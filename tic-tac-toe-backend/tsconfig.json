{
  "compilerOptions": {
    "target": "es5",
    "module": "ES2015",
    "lib": ["es5", "es2015.core", "es2015.collection", "es2015.iterable"],
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "typeRoots": [
      "./node_modules/@types",
      "./types"
    ]
  },
  "include": ["src/**/*.ts", "types/**/*.d.ts"]
}

